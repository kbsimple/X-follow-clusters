# X API Credentials
# Required for Phase 2+ (profile enrichment and X API list creation)
# Phase 1 (archive parsing) works without these - no API calls are made
#
# Obtain credentials at: https://developer.x.com/en/docs/twitter-api/twitter-api-labs
#
# IMPORTANT: Never commit this file with real credentials!
# Copy this to .env and fill in your actual values:
#   cp .env.example .env

X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
X_BEARER_TOKEN=your_bearer_token_here  # optional if OAuth credentials above provided

# Alternative: Use scraping services instead of X API (see docs/auth-alternatives.md)
# APIFY_API_TOKEN=your_apify_token
# BRIGHT_DATA_ZONE=your_zone
